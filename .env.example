# ============================================================
# CrowdLabel — пример переменных окружения
# 12-factor Factor III: Config stored in the environment
# ============================================================
# Скопируйте этот файл в .env и заполните своими значениями
# НИКОГДА не коммитьте .env в Git!
# ============================================================

# ─── Security ──────────────────────────────────────────────
# Генерация: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-change-this-in-production

# ─── Database ──────────────────────────────────────────────
POSTGRES_USER=crowdlabel
POSTGRES_PASSWORD=crowdlabel_secret
POSTGRES_DB=crowdlabel
# Автоматически собирается из переменных выше в docker-compose.yml
# Для локального запуска без Docker задайте явно:
# DATABASE_URL=postgresql+asyncpg://crowdlabel:crowdlabel_secret@localhost/crowdlabel

# ─── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── App ───────────────────────────────────────────────────
DEBUG=false
ENVIRONMENT=development

# ─── Frontend ──────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
